{
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@@/*": ["src/.umi/*"],
      "root/*": ["../*"]
    },
    "types": [
      "node",
      "react",
      "react-dom",
      "jest",
      "dompurify",
      "lodash",
      "react-copy-to-clipboard",
      "react-syntax-highlighter",
      "uuid",
      "webpack-env"
    ]
  },
  "include": ["src", "typings.d.ts", "externals.d.ts"]
}
