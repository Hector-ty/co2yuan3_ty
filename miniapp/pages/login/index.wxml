<view class="page">
  <view class="card">
    <view class="card-title">碳排放管理平台登录</view>
    <view class="form-item">
      <text class="label">账号</text>
      <input class="input" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameChange" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordChange" />
    </view>
    <button class="primary-btn login-btn" loading="{{loading}}" bindtap="onSubmit">登录</button>
    <view wx:if="{{error}}" class="error-text">{{error}}</view>
  </view>
</view>

