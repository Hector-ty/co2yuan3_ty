.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #555555;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  border-radius: 8rpx;
  border: 1rpx solid #dddddd;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.login-btn {
  margin-top: 32rpx;
}

.error-text {
  margin-top: 16rpx;
  color: #d32f2f;
  font-size: 24rpx;
}

