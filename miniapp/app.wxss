page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
}

.primary-btn {
  background-color: #1976d2;
  color: #ffffff;
  border-radius: 4rpx;
}

.card {
  margin: 24rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.kpi-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1976d2;
}

.kpi-label {
  font-size: 24rpx;
  color: #666666;
}

