# Server Port
PORT=5000

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/carbon_platform

# JSON Web Token Secret
JWT_SECRET=your_jwt_secret

# RAGFlow 知识库（报告导出 AI 内容生成，可选；未配置时使用 Ollama）
# RAGFlow API 地址，如 http://localhost:8082 或 http://ragflow:9380
# RAGFLOW_API_URL=
# RAGFlow API 密钥（Bearer），在 RAGFlow 中创建分享链接时的 auth 参数，或用户 API Key
# RAGFLOW_API_KEY=
# 指定知识库名称，默认 co2yuan3；若能与 datasets API 解析成功，则优先使用该知识库
# RAGFLOW_KB_NAME=co2yuan3
# 或直接指定知识库 ID（在 RAGFlow 知识库详情页获取），优先于 KB_NAME
# RAGFLOW_KB_ID=
# 已分享的对话 ID（chatbots 接口），当未配置 KB_ID/KB_NAME 时使用
# RAGFLOW_DIALOG_ID=

# 报告生成调试：设为 1 时在 backend 日志中输出 document.xml 相关调试信息（Docker 部署时在项目根目录 .env 中设置）
DEBUG_REPORT_XML=1
